# --- Cloned upstream dependencies (fetched by setup/install_ros_gaden.sh) ---
# GADEN is cloned+built in place; it is NOT part of this repo.
/gaden/
/ros2_ws/src/gaden/
/ros2_ws/src/olfaction_msgs/

# --- ROS runtime logs (redirected here so the sandbox can write) ---
/.roslog/

# --- Scenes generated by export_scene / odor_sim.make (reproducible) ---
# Keep the hand-authored scene1.yaml; ignore everything make() emits.
/scenarios/**/scenes/*.yaml
!/scenarios/**/scenes/scene1.yaml
/scenarios/**/simulations/src[0-9]*/

# --- colcon build artifacts ---
/ros2_ws/build/
/ros2_ws/install/
/ros2_ws/log/
build/
install/
log/

# --- Deprecated playground (kept locally for cherry-picking, not tracked) ---
/simulation/

# --- Local-only docs / setup notes / tests (kept on disk, not in git) ---
/docs/
/tests/
/SETUP.md
/VNC_SETUP.md
/setup_gaden.sh
/README_DEV.md

# --- Python envs & packaging ---
.venv/
venv/
*.egg-info/
__pycache__/
*.py[cod]
.python-version

# --- Datasets & large artifacts ---
/datasets/
*.mp4
MUJOCO_LOG.TXT

# --- Editor / OS ---
.DS_Store
.idea/
.vscode/
